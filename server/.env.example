# Local dev (host machine):
# DATABASE_URL=postgresql://flowie:flowie@localhost:54321/flowie?schema=public
DATABASE_URL=postgresql://flowie:flowie@db:5432/flowie?schema=public

# Telegram bot token (secret)
BOT_TOKEN=change-me

# JWT secret for your app sessions (secret)
APP_JWT_SECRET=change-me

# Cookie domain (optional, e.g. .flowie.app)
APP_COOKIE_DOMAIN=

# development|production
NODE_ENV=development

# Optional admin bootstrap, comma-separated Telegram IDs
ADMIN_TG_IDS=
ADMIN_BOT_TOKEN=
